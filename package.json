{
  "name": "echogrid",
  "version": "0.1.0",
  "description": "Agent-first CLI-native inference and planning game demo.",
  "license": "UNLICENSED",
  "type": "commonjs",
  "bin": {
    "echogrid": "./bin/echogrid.js"
  },
  "scripts": {
    "start": "node ./bin/echogrid.js",
    "test": "node --test",
    "demo": "node ./bin/echogrid.js evaluate --agent ./agents/baseline.js --seeds ./seeds/public.txt",
    "demo:full": "node ./scripts/demo-full.js",
    "demo:verify": "npm test && node ./bin/echogrid.js evaluate --agent ./agents/rule-aware.js --seed 9001 --json && node ./scripts/compare.js --seeds ./seeds/showcase.txt",
    "demo:brief": "node ./scripts/write-judge-brief.js ./logs/showcase/9001.jsonl --out ./logs/showcase/JUDGE_BRIEF.md --replay-html ./logs/showcase/replay.html --arena-html ./logs/showcase/arena.html --leaderboard ./logs/showcase/leaderboard.md --comparison ./logs/showcase/agent-comparison.txt",
    "demo:scorecard": "node ./scripts/write-demo-scorecard.js ./logs/showcase/9001.jsonl --out ./logs/showcase/SCORECARD.md --comparison-json ./logs/showcase/agent-comparison.json",
    "demo:index": "node ./scripts/write-demo-index.js ./logs/showcase/9001.jsonl --out ./logs/showcase/index.html --manifest ./logs/showcase/MANIFEST.json --scorecard ./logs/showcase/SCORECARD.md --brief ./logs/showcase/JUDGE_BRIEF.md --replay-html ./logs/showcase/replay.html --arena-html ./logs/showcase/arena.html --leaderboard ./logs/showcase/leaderboard.md --comparison-json ./logs/showcase/agent-comparison.json",
    "demo:manifest": "node ./scripts/write-demo-manifest.js ./logs/showcase/9001.jsonl --out ./logs/showcase/MANIFEST.json --index ./logs/showcase/index.html --scorecard ./logs/showcase/SCORECARD.md --brief ./logs/showcase/JUDGE_BRIEF.md --replay-html ./logs/showcase/replay.html --arena-html ./logs/showcase/arena.html --leaderboard ./logs/showcase/leaderboard.md --comparison-json ./logs/showcase/agent-comparison.json --comparison ./logs/showcase/agent-comparison.txt",
    "demo:check": "node ./scripts/verify-demo-artifacts.js ./logs/showcase",
    "demo:ci": "npm run demo:full && npm run demo:check",
    "compare": "node ./scripts/compare.js --seeds ./seeds/demo.txt",
    "benchmark:adversarial": "node ./scripts/compare.js --seeds ./seeds/adversarial.txt --json-out ./logs/adversarial/agent-comparison.json --html-out ./logs/adversarial/arena.html --leaderboard-out ./logs/adversarial/leaderboard.md",
    "showcase": "node ./bin/echogrid.js evaluate --agent ./agents/rule-aware.js --seed 9001 --log-dir ./logs/showcase",
    "llm:smoke": "node ./scripts/run-llm-eval.js --models deepseek-v4-pro,deepseek-v4-flash --seeds ./seeds/llm-smoke.txt --mode micro --max-model-turns 12 --leaderboard both",
    "llm:summary": "node ./scripts/summarize-llm-logs.js ./logs/llm",
    "analyze": "node ./scripts/analyze-run.js",
    "replay:html": "node ./scripts/render-replay-html.js",
    "run:sample": "node ./bin/echogrid.js run --seed 48129 --script ./scripts/sample.eg --log ./logs/sample.48129.jsonl",
    "replay:sample": "node ./bin/echogrid.js replay ./logs/sample.48129.jsonl",
    "report:sample": "node ./bin/echogrid.js report ./logs/sample.48129.jsonl"
  },
  "engines": {
    "node": ">=20"
  }
}
